# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── API Security ─────────────────────────────────────────────────────────────
# Clients must send this in X-Api-Secret header (not required in development)
API_SECRET=replace_with_a_strong_random_secret

# Shared secret between backend and every helper agent
HELPER_AGENT_SECRET=replace_with_another_strong_secret

# ── Software passwords ────────────────────────────────────────────────────────
# Injected wherever {{PASSWORD}} appears in generated install commands
DEFAULT_SOFTWARE_PASSWORD=R0ll3rcoaster#123456

# ── SSH fallback credentials ──────────────────────────────────────────────────
SSH_USERNAME=admin
SSH_PRIVATE_KEY_PATH=/path/to/your/private_key
# SSH_PASSWORD=only_if_key_auth_not_available

# ── WinRM fallback credentials ────────────────────────────────────────────────
WINRM_USERNAME=Administrator
WINRM_PASSWORD=replace_with_winrm_password
WINRM_DOMAIN=COMPANY
WINRM_PORT=5985

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── Machine registry ──────────────────────────────────────────────────────────
MACHINES_FILE=./src/config/machines.json

# ── Helper agent ──────────────────────────────────────────────────────────────
HELPER_AGENT_PORT=7334
HELPER_HEALTH_TIMEOUT_MS=5000

# URL prefix where install scripts are served (e.g. your static file server)
# HELPER_DOWNLOAD_URL=https://it.company.com/installer-agent
