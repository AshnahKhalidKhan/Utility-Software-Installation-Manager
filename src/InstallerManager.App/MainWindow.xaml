<Window x:Class="InstallerManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Utility Software Installation Manager"
        Height="640"
        Width="980"
        MinHeight="480"
        MinWidth="720">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <DockPanel Margin="12">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,8"
                Padding="10"
                Background="#FFF8E1"
                BorderBrush="#FFC107"
                BorderThickness="1"
                CornerRadius="2"
                Visibility="{Binding ShowElevationBanner, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Foreground="#5D4037"
                           Text="Not running as Administrator — installs/uninstalls will usually fail. Use the button to restart with UAC (works with dotnet run and the .exe), or right-click InstallerManager.exe → Run as administrator." />
                <Button Grid.Column="1"
                        Margin="12,0,0,0"
                        MinWidth="200"
                        Height="32"
                        VerticalAlignment="Center"
                        Content="Restart as administrator"
                        Command="{Binding RestartAsAdministratorCommand}" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Padding="0,0,0,12">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Utility Software Installation Manager" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#444"
                           TextWrapping="Wrap"
                           Text="Select packages, then install or uninstall. Catalog: Data/catalog.json (edit to pin versions or swap installers). Administrator rights are required for most operations." />
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button MinWidth="120"
                    Height="32"
                    Margin="0,0,8,0"
                    Content="Install selected"
                    Command="{Binding InstallSelectedCommand}" />
            <Button MinWidth="120"
                    Height="32"
                    Content="Uninstall selected"
                    Command="{Binding UninstallSelectedCommand}" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="160" MinHeight="120" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Header="Include"
                                            Width="70" />
                    <DataGridTextColumn Binding="{Binding Category}"
                                        Header="Category"
                                        Width="180"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Binding="{Binding DisplayName}"
                                        Header="Software"
                                        Width="*"
                                        MinWidth="160"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Binding="{Binding VersionHint}"
                                        Header="Version"
                                        Width="100"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Binding="{Binding Notes}"
                                        Header="Notes"
                                        Width="2*"
                                        MinWidth="200"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          ShowsPreview="False" />

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,4" Text="Activity log" />
                <TextBox Text="{Binding ActivityLog, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="No" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
